{
  "name": "orchestra",
  "version": "1.0.0",
  "description": "Local-first workflow orchestration tool",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "packages/electron/dist/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "electron:build": "tsc -p packages/electron",
    "electron:watch": "tsc -w -p packages/electron",
    "client:dev": "npm run dev -w @orchestra/client",
    "client:build": "npm run build -w @orchestra/client",
    "web:dev": "npm run dev -w @orchestra/web",
    "web:build": "npm run build -w @orchestra/web",
    "dev": "npm run dev -w @orchestra/client",
    "build": "npm run electron:build && npm run client:build",
    "start": "npm run electron:build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "child_process": "^1.0.2",
    "node-pty": "^1.1.0",
    "strip-ansi": "^7.2.0",
    "yaml": "^2.8.3"
  },
  "build": {
    "appId": "com.orchestra.app",
    "asar": true,
    "productName": "Orchestra",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "packages/electron/dist/**/*",
      "packages/electron/preload.js",
      "packages/client/dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
